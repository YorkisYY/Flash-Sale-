# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit real credentials.

# ----- Database (local dev defaults match docker-compose) -----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=flashsale
DB_USER=flashsale
DB_PASSWORD=flashsale

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379

# ----- Server -----
SERVER_PORT=8080

# ----- PayUni (test mode) ---------------------------------------------------
# Get these from the PayUni merchant console after registering for a test
# account at https://www.payuni.com.tw/ . The exact field names PayUni uses
# (MerID vs MerchantID, HashKey vs Hash_IV vs Key, etc.) come from the
# official PayUni test-environment docs — paste those into the project before
# implementing PayUniProvider; do not guess.
#
# PAYUNI_ENV is the switch between PayUni's test and prod base URLs.
# Leave on "test" for this v1 (real money is out of scope).
PAYUNI_MERCHANT_ID=replace-with-your-payuni-test-merchant-id
PAYUNI_HASH_KEY=replace-with-your-payuni-hash-key
PAYUNI_HASH_IV=replace-with-your-payuni-hash-iv
PAYUNI_ENV=test

# Server-to-server notify URL — PayUni posts here when a payment is captured.
# Must be reachable from the public internet, so for local dev use ngrok /
# cloudflared (see README). If you only run docker-compose without a tunnel,
# PayUni cannot reach localhost — you can still exercise the rest of the flow
# manually but the PAID transition will require a curl-simulated callback.
PAYUNI_NOTIFY_URL=http://localhost:8080/api/payments/payuni/callback

# Browser-return URL after the buyer finishes the PayUni checkout.
PAYUNI_RETURN_URL=http://localhost:8080/api/payments/payuni/callback

# Where the backend should bounce the browser back to after a successful payment
# (your frontend result page; we append the orderId).
PAYUNI_FRONTEND_RESULT_URL=http://localhost:3000/result

# ----- Stripe (test mode) ---------------------------------------------------
# Get from: https://dashboard.stripe.com/test/apikeys
# For local webhook testing: install the Stripe CLI and run
#   stripe listen --forward-to localhost:8080/api/payments/stripe/callback
# The CLI prints a whsec_… that goes into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=sk_test_replace_me
# Publishable key — only needed if the frontend ever calls Stripe Elements
# directly. The backend doesn't read it; kept here so all Stripe creds live
# together.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=twd
STRIPE_SUCCESS_URL=http://localhost:3000/result
STRIPE_CANCEL_URL=http://localhost:3000/result

# ----- ECPay (test mode / 綠界測試環境) -------------------------------------
# These are ECPay's *publicly published* test credentials — safe to commit as
# examples. Use them only against payment-stage.ecpay.com.tw. Replace with
# real merchant credentials for production.
# Reference: https://www.ecpay.com.tw/Service/API_Dwnld
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=pwFHCqoQZGmoCv08Q3XY
ECPAY_HASH_IV=EkRm7iFT760PKIKAKExC
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# ReturnURL must be publicly reachable. Use ngrok / cloudflared in local dev.
ECPAY_RETURN_URL=http://localhost:8080/api/payments/ecpay/callback
# Browser-redirect destination after payment (frontend result page; we suffix /{orderId}).
ECPAY_ORDER_RESULT_URL=http://localhost:3000/result
ECPAY_CLIENT_BACK_URL=http://localhost:3000
