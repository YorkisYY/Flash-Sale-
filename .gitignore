# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Backend
backend/target/
backend/.classpath
backend/.project
backend/.settings/
backend/*.iml

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.vercel

# Loadtest
loadtest/node_modules/

# Local logs — anything *.log at the repo root is a local-dev artifact
# (cloudflared-tunnel.log, stripe-listen.log, etc.)
*.log

# Local-dev scratch from manual ECPay sandbox runs (generated forms,
# signed-callback payloads, curl arg files). Regeneratable from the
# backend at any time; never load-bearing.
ecpay-redirect.html
ecpay-session.json
_sess*.json
*.args

# Stand-alone ECPay-callback signing tool — public stage HashKey/HashIV
# in plaintext; useful for debugging but doesn't belong in git.
SignEcpayCallback.java

# Docker
docker-compose.override.yml

# Kubernetes secrets — the committed k8s/secret.yaml holds REPLACE_ME
# placeholders ONLY. Real values go in a *.local.yaml copy that must never
# be committed (see k8s/README.md).
k8s/secret.local.yaml
k8s/*.local.yaml

# OS
Thumbs.db
